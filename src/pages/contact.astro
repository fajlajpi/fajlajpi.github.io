---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/Sections/PageHeader.astro";
import Button from "../components/UI/Button.astro";
---

<BaseLayout
  title="Book a Tour – Blue Fox Tours"
  description="Request a private tour of Prague or a Theresienstadt day trip. I reply within 24 hours."
>
  <PageHeader
    title="Book a Tour"
    subtitle="Tell me when you're coming and who's coming with you – I reply within 24 hours."
    backgroundImage="/uploads/contact-header-bg.webp"
  />

  <section class="section-y">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <!-- Booking Request Form -->
        <div>
          <h2 class="text-3xl font-bold mb-6">Request a Tour</h2>
          <p class="text-gray-700 mb-6">
            All tours are private – it's just your group and me. Send a request
            and I'll confirm availability within 24 hours. No payment is taken
            until we've confirmed the details together.
          </p>

          
          <form
            action="https://formspree.io/f/xjgqqgay"
            method="POST"
            class="space-y-6"
          >
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-primary-500 focus:border-primary-500"
              />
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-primary-500 focus:border-primary-500"
              />
            </div>

            <div>
              <label for="tour" class="block text-sm font-medium text-gray-700 mb-1">Which tour?</label>
              <select
                id="tour"
                name="tour"
                required
                class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-primary-500 focus:border-primary-500"
              >
                <option value="">Please select</option>
                <option value="Old Town, Jewish Quarter & Charles Bridge (3h private tour)">
                  Old Town, Jewish Quarter &amp; Charles Bridge – 3h private tour
                </option>
                <option value="Theresienstadt by Train (full-day private trip)">
                  Theresienstadt by Train – full-day private trip
                </option>
                <option value="Custom / something else">
                  Custom tour / something else
                </option>
              </select>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="date" class="block text-sm font-medium text-gray-700 mb-1">Preferred date</label>
                <input
                  type="date"
                  id="date"
                  name="preferred_date"
                  required
                  class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-primary-500 focus:border-primary-500"
                />
              </div>

              <div>
                <label for="group-size" class="block text-sm font-medium text-gray-700 mb-1">Group size</label>
                <select
                  id="group-size"
                  name="group_size"
                  required
                  class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-primary-500 focus:border-primary-500"
                >
                  <option value="">Please select</option>
                  <option value="1–2 people">1–2 people</option>
                  <option value="3–4 people">3–4 people</option>
                  <option value="5–6 people">5–6 people</option>
                  <option value="7+ people">7+ people (let's talk)</option>
                </select>
              </div>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-1">
                Anything I should know? <span class="text-gray-500 font-normal">(interests, kids, mobility, alternative dates)</span>
              </label>
              <textarea
                id="message"
                name="message"
                rows="5"
                class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-primary-500 focus:border-primary-500"
              ></textarea>
            </div>

            <!-- Honeypot field for spam bots -->
            <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />

            <div>
              <Button type="submit" variant="primary">
                Send request
              </Button>
            </div>
          </form>
        </div>

        <!-- Direct Contact -->
        <div>
          <h2 class="text-3xl font-bold mb-6">Or reach me directly</h2>

          <div class="bg-gray-50 p-6 rounded-lg shadow-sm mb-6">
            <h3 class="text-xl font-bold mb-2">Email</h3>
            <p class="text-gray-700 mb-4">
              Prefer to just write? Works exactly the same.
            </p>
            <div class="flex items-center text-gray-700">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <a href="mailto:info@bluefoxtours.cz" class="text-primary-600 hover:text-primary-700">
                info@bluefoxtours.cz
              </a>
            </div>
          </div>

          <div class="bg-gray-50 p-6 rounded-lg shadow-sm mb-6">
            <h3 class="text-xl font-bold mb-2">WhatsApp</h3>
            <p class="text-gray-700 mb-4">
              Fastest way to reach me while you're traveling.
            </p>
            <div class="flex items-center text-gray-700">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <a href="https://wa.me/420773537656" class="text-primary-600 hover:text-primary-700">
                +420 773 537 656
              </a>
            </div>
          </div>

          <div class="bg-gray-50 p-6 rounded-lg shadow-sm">
            <h3 class="text-xl font-bold mb-2">How booking works</h3>
            <ol class="list-decimal list-inside text-gray-700 space-y-2">
              <li>You send a request with your date and group size.</li>
              <li>I confirm availability within 24 hours.</li>
              <li>We agree on a meeting point and any customizations.</li>
              <li>You pay after the tour – cash or card.</li>
            </ol>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
