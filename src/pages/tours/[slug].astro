---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostLayout from "../../layouts/PostLayout.astro";
import Button from "../../components/UI/Button.astro";
import { getCollection } from "astro:content";
import { formatDate } from "../../utils/dateUtils";

// Generate static paths for all tours
export async function getStaticPaths() {
  try {
    const tourEntries = await getCollection("tours", ({ data }) => {
      return import.meta.env.PROD ? !data.draft : true;
    });

    return tourEntries.map(entry => ({
      params: { slug: entry.slug },
      props: { entry },
    }));
  } catch (error) {
    // If the collection doesn't exist yet, return an empty array
    return [];
  }
}

// Get the tour data
const { entry } = Astro.props;
const { Content } = await entry.render();

// Build TouristTrip structured data for this tour
const siteUrl = Astro.site?.toString() || "https://bluefoxtours.cz";
const tourSchema = {
  "@context": "https://schema.org",
  "@type": "TouristTrip",
  name: entry.data.title,
  description: entry.data.summary,
  image: entry.data.image ? new URL(entry.data.image, Astro.site).toString() : undefined,
  touristType: "Private group",
  provider: { "@id": `${siteUrl}#business` },
  offers: entry.data.pricingTiers?.length
    ? {
        "@type": "AggregateOffer",
        priceCurrency: "EUR",
        lowPrice: Math.min(...entry.data.pricingTiers.map((t) => t.price)),
        highPrice: Math.max(...entry.data.pricingTiers.map((t) => t.price)),
        offerCount: entry.data.pricingTiers.length,
      }
    : {
        "@type": "Offer",
        priceCurrency: "EUR",
        price: entry.data.price,
      },
};

// "From" price for display (lowest tier, or the flat price)
const fromPrice = entry.data.pricingTiers?.length
  ? Math.min(...entry.data.pricingTiers.map((t) => t.price))
  : entry.data.price;

// Find related tours from the same tourType (if available)
let relatedtours = [];
if (entry.data.tourType) {
  try {
    const alltours = await getCollection("tours", ({ data }) => {
      return import.meta.env.PROD ? !data.draft : true;
    });
    
    relatedtours = alltours
      .filter(tour => 
        tour.data.tourType === entry.data.tourType && tour.slug !== entry.slug
      )
      .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
      .slice(0, 3);
  } catch (error) {
    console.log("Error fetching related tours");
  }
}
---

<BaseLayout
  title={`${entry.data.title} - Tours - Blue Fox Tours`}
  description={entry.data.summary || `${entry.data.title} – a private tour by Blue Fox Tours, Prague.`}  image={entry.data.image ? { url: entry.data.image, alt: entry.data.title } : undefined}
  type="article"
  structuredData={[tourSchema]}
>
  <PostLayout
    title={entry.data.title}
    description={entry.data.summary}
    image={entry.data.image ? { url: entry.data.image, alt: entry.data.title } : undefined}
    tags={entry.data.tags}
    type="tour"
  >
    <!-- Tour Details -->
    <div class="bg-gray-50 rounded-lg p-6 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {
          entry.data.tourType && (
            <div>
              <h3 class="text-lg font-bold mb-2">Tour Type</h3>
              <p class="flex items-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 text-primary-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                </svg>
                {entry.data.tourType}
              </p>
            </div>
          )
        }

        <div>
          <h3 class="text-lg font-bold mb-2">Duration</h3>
          <p class="flex items-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 text-primary-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            {entry.data.duration}
          </p>
        </div>

        <div>
          <h3 class="text-lg font-bold mb-2">Price</h3>
          <p class="flex items-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 text-primary-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5a1.99 1.99 0 011.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.99 1.99 0 013 12V7a4 4 0 014-4z" />
            </svg>
            From €{fromPrice} per group
          </p>
        </div>

        {
          entry.data.meetingPoint && (
            <div>
              <h3 class="text-lg font-bold mb-2">Meeting Point</h3>
              <p class="flex items-start">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 mt-0.5 text-primary-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                {entry.data.meetingPoint}
              </p>
            </div>
          )
        }
      </div>

      {
        entry.data.pricingTiers && entry.data.pricingTiers.length > 0 && (
          <div class="mt-6 pt-6 border-t border-gray-200">
            <h3 class="text-lg font-bold mb-3">Pricing (per group)</h3>
            <ul class="space-y-1">
              {entry.data.pricingTiers.map((tier) => (
                <li class="flex justify-between max-w-xs">
                  <span>{tier.label}</span>
                  <span class="font-medium">€{tier.price}</span>
                </li>
              ))}
            </ul>
          </div>
        )
      }

      {
        entry.data.priceIncludes && entry.data.priceIncludes.length > 0 && (
          <div class="mt-6 pt-6 border-t border-gray-200">
            <h3 class="text-lg font-bold mb-3">What's included</h3>
            <ul class="space-y-2">
              {entry.data.priceIncludes.map((item) => (
                <li class="flex items-start">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 mt-0.5 text-primary-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        )
      }
    </div>

    <!-- Video -->
    {
      entry.data.videoUrl && (
        <div class="mb-8">
          <h3 class="text-xl font-bold mb-4">Watch</h3>
          <div class="relative w-full overflow-hidden rounded-lg" style="padding-top: 56.25%">
            <iframe
              class="absolute inset-0 h-full w-full"
              src={entry.data.videoUrl}
              title={`${entry.data.title} video`}
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            />
          </div>
        </div>
      )
    }

    <!-- Tour Content -->
    <article class="prose prose-lg max-w-none prose-headings:text-gray-900 prose-h1:text-3xl prose-h2:text-2xl prose-h3:text-xl prose-h4:text-lg prose-p:text-gray-700 prose-li:text-gray-700 prose-strong:text-gray-900 prose-a:text-primary-600 hover:prose-a:text-primary-700">
      <Content />
    </article>
    
    <!-- Related tours -->
    {
      relatedtours.length > 0 && (
        <div class="mt-12">
          <h2 class="text-2xl font-bold mb-6">More From This Series</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {relatedtours.map(tour => (
              <a href={`/tours/${tour.slug}`} class="block bg-gray-50 rounded-lg p-4 hover:bg-gray-100 transition-colors">
                <h3 class="font-bold mb-2">{tour.data.title}</h3>
                <p class="text-sm text-gray-600 mb-2">{formatDate(tour.data.date)}</p>
                <p class="text-primary-600 text-sm font-medium">Listen/Watch →</p>
              </a>
            ))}
          </div>
        </div>
      )
    }
    
    <!-- Action Buttons -->
    <div class="mt-12 flex flex-wrap gap-4">
      <Button href="/tours" variant="outline">
        Back to All tours
      </Button>
      
      {
        entry.data.series && (
          <Button href={`/tours?tourType=${encodeURIComponent(entry.data.tourType)}`} variant="outline">
            View All in This Series
          </Button>
        )
      }
    </div>
  </PostLayout>
</BaseLayout>