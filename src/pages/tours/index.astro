---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/Sections/PageHeader.astro";
import Card from "../../components/UI/Card.astro";
import { getCollection } from "astro:content";

// Get all tours
const allTours = await getCollection("tours", ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

// Sort by date (newest first)
const tours = allTours.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout
  title="Tours - Blue Fox Tours"
  description="Selection of tours we offer, cover a wide variety of subjects, areas and periods of history."
>
  <PageHeader 
    title="Our Tours" 
    subtitle="Established tours ready for you to join, or a bouncing off point for a custom experience."
    backgroundImage="/uploads/tours-header-bg.jpg"
  />
  
  <!-- tours List -->
  <section class="section-y">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- tours Grid -->
        <div class="lg:col-span-3">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8" id="tours-grid">
            {tours.map((tour) => (
              <Card
                title={tour.data.title}
                image={{
                  src: tour.data.image || "/uploads/tour-placeholder.webp",
                  alt: tour.data.title
                }}
                href={`/tours/${tour.slug}/`}
                className="tour-card"
                data-tourtype={tour.data.tourType || ""}
                data-date={tour.data.date.toISOString().slice(0, 10)}
              >
                <div class="mb-3 flex items-center text-gray-600">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <span>{tour.data.duration}</span>
                </div>

                {tour.data.tourType && (
                  <div class="mb-3 flex items-center text-gray-600">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                    </svg>
                    <span>{tour.data.tourType}</span>
                  </div>
                )}

                <div class="mb-3 flex items-center text-gray-600">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5a1.99 1.99 0 011.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.99 1.99 0 013 12V7a4 4 0 014-4z" />
                  </svg>
                  <span>From €{tour.data.pricingTiers?.length ? Math.min(...tour.data.pricingTiers.map((t) => t.price)) : tour.data.price} per group</span>
                </div>

                <p class="text-gray-700 mb-4">{tour.data.summary}</p>

                <p class="text-primary-600 font-medium group-hover:underline group-hover:text-primary-700">
                  Learn more →
                </p>
              </Card>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
