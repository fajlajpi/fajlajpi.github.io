---
// Seo.astro — Blue Fox Tours
// NOTE: The original template used ${...} interpolation inside a plain
// <script type="application/ld+json"> block. Astro does NOT interpolate
// there, so the site was emitting literal "${churchInfo.name}" strings —
// invalid JSON-LD. This version serializes real objects with JSON.stringify
// and injects them via set:html, which is the correct Astro pattern.

export interface Props {
  title: string;
  description: string;
  image?: {
    url: string;
    alt: string;
  };
  type?: "website" | "article";
  canonicalUrl?: string;
  /** Optional extra JSON-LD objects (e.g. TouristTrip from a tour page) */
  structuredData?: object[];
}

const {
  title,
  description,
  image = {
    url: "/uploads/bluefox-thumb.png",
    alt: "Blue Fox Tours",
  },
  type = "website",
  canonicalUrl,
  structuredData = [],
} = Astro.props;

const canonicalURL = canonicalUrl || new URL(Astro.url.pathname, Astro.site);

// ── Business info ────────────────────────────────────────────────────────
// IMPORTANT: name / address / phone must match your Google Business Profile
// EXACTLY (same spelling, same formatting). Fill in the TODOs before deploy.
const business = {
  name: "Blue Fox Tours",
  legalName: "Filip Huta",
  addressLocality: "Prague",
  addressCountry: "CZ",
  telephone: "+420773537656",
  email: "info@bluefoxtours.cz",
  url: Astro.site?.toString() || "https://bluefoxtours.cz",
  image: new URL(image.url, Astro.site).toString(),
  priceRange: "€€€",
};

// Site-wide LocalBusiness schema. schema.org has no "TourOperator" type;
// TravelAgency is the accepted type for tour operators and what Google's
// documentation examples use for this category.
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "TravelAgency"],
  "@id": `${business.url}#business`,
  name: business.name,
  description:
    "Private walking tours of Prague and day trips to Theresienstadt (Terezín), led by a licensed local guide with 15 years of experience.",
  telephone: business.telephone,
  email: business.email,
  url: business.url,
  image: business.image,
  priceRange: business.priceRange,
  areaServed: [
    { "@type": "City", name: "Prague" },
    { "@type": "City", name: "Terezín" },
  ],
  founder: {
    "@type": "Person",
    name: "Filip Huta",
    jobTitle: "Licensed Tour Guide",
  },
  knowsLanguage: ["en", "cs"],
};

const articleSchema =
  type === "article"
    ? {
        "@context": "https://schema.org",
        "@type": "Article",
        headline: title,
        image: new URL(image.url, Astro.site).toString(),
        description: description,
        publisher: {
          "@type": "Organization",
          name: business.name,
          logo: {
            "@type": "ImageObject",
            url: new URL("/uploads/bluefox.png", Astro.site).toString(),
          },
        },
        url: canonicalURL.toString(),
        mainEntityOfPage: {
          "@type": "WebPage",
          "@id": canonicalURL.toString(),
        },
      }
    : null;

const allSchemas = [
  localBusinessSchema,
  ...(articleSchema ? [articleSchema] : []),
  ...structuredData,
];
---

<!-- Basic SEO -->
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image.url, Astro.site)} />
<meta property="og:image:alt" content={image.alt} />
<meta property="og:locale" content="en_US" />
<meta property="og:site_name" content="Blue Fox Tours" />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image.url, Astro.site)} />
<meta property="twitter:image:alt" content={image.alt} />

<!-- JSON-LD structured data (valid serialization) -->
{
  allSchemas.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))
}
